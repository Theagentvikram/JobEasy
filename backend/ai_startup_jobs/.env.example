# ──────────────────────────────────────────────
# AI Startup Jobs Pipeline — Environment Config
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── APIFY (LinkedIn scraper) ──────────────────
# Free tier: $5/month compute included
# Sign up at: https://apify.com
# Get token: https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_token_here

# ── GOOGLE SHEETS ─────────────────────────────
# Create a Google Sheet at: https://sheets.google.com
# Copy the Sheet ID from the URL:
#   https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID_HERE/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Path to your Google OAuth credentials JSON file
# See README for how to create this:
GOOGLE_CREDS_FILE=credentials.json

# ── OPTIONAL SETTINGS ─────────────────────────
# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Max jobs per source (increase to get more results)
MAX_JOBS_PER_SOURCE=100
